extends layout

block lobby-panel
    div.lobby-wrapper.panel#lobbyPanel
        h2.lobby-title.text-center.flicker1 Lobby
        form.room-actions(method="POST" action="/room")
            div.room-options
                label.private-room
                    span Priv
                    input#privateRoom(type="checkbox" name="private")
                select#selectDuration(name="duration")
                    option(value="120" selected) 2m
                    option(value="300") 5m
                    option(value="600") 10m
                select#selectMode(name="mode")
                    option(value="1vs1" selected) 1v1
                    option(value="2vs2") 2v2
                    option(value="3vs3") 3v3
                    option(value="practica") Practica
                div.ball-selector
                    input#selectBall(type="hidden" name="ball" value="texture-1")
                    div.ball-selector-display
                        div.ball-option.ball-selected(data-ball="texture-1")
                        i.bi.bi-chevron-down.ball-dropdown-icon
                    div.ball-selector-dropdown
                        div.ball-option(data-ball="texture-1")
                        div.ball-option(data-ball="texture-2")
                        div.ball-option(data-ball="texture-3")

            button.btn.btn-primary.w-100(type="submit")
                i.bi.bi-plus-square
                span Crear sala

        div.room-join-by-id

        div.room-list
            h3.lobby-title.text-center Salas
            div#rooms
                p.text-center No hay salas disponibles

block main
    //- Mensaje de rotación (solo visible en portrait mode)
    div.rotate-message
        i.bi.bi-phone-landscape.flicker2
        h2.flicker1 Gira tu dispositivo
        p Para una mejor experiencia de juego.

    //- Botones hamburguesa (solo visibles en móvil/tablet landscape)
    button.hamburger-btn.left#lobbyToggle(aria-label="Toggle Lobby")
        i.bi.bi-card-list
    button.hamburger-btn.right#userToggle(aria-label="Toggle User Panel")
        i.bi.bi-person-square

    div.overlay#overlay

    div.main-wrapper.panel
        div#scoreboard
            span#score 0 - 0
            h1.main-title.flicker Snake Soccer
            span#timer 0:00
        div.canvas-wrapper
            canvas#gameCanvas

block user-panel
    div.user-wrapper.panel#userPanel
        h2.user-title.flicker2 #{user.username}
        div.experience-container
            div.experience-bar-background
                div#xpBarFill
            div.experience-info
                p.experience-text
                    include partials/level-up.svg 
                    span#statLevel Lvl 1
                p.experience-text
                    span#statXp 0/0 XP
        div.nav-list
            div.nav-item
                button.btn.btn-primary.nav-link.w-100#themeToggle(type="button")
                    i.bi.bi-palette
                    span Temas
            if user && user.role === 'admin'
                div.nav-item
                    a.btn.btn-primary.nav-link.w-100(href="/tasks")
                        i.bi.bi-clipboard-check
                        span Tareas
        if user
            div.nav-item
                form(method="POST", action="/logout")
                    button.btn.leave-btn.nav-link.w-100(type="submit")
                        i.bi.bi-door-closed
                        span Salir

        if user
            div.user-stats
                p
                    include partials/ball-icon.svg 
                    span#statGoals Goles: 0 
                p
                    include partials/high-five.svg 
                    span#statAssists Asistencias: 0
                p
                    i.bi.bi-joystick 
                    span#statMatches Partidas: 0
                p
                    i.bi.bi-graph-up 
                    span#statWinrate Winrate: 0%
                a.btn.btn-primary.w-100.mt-2(href="/ranking")
                    i.bi.bi-bar-chart 
                    span Rankings

block scripts
    script(src="/socket.io/socket.io.js")
    script(src="/js/lobbyUI.js")
